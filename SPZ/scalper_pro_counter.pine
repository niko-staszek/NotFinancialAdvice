//@version=6
// =============================================================================
// Scalper Pro — TP/SL Counter  [companion]
// -----------------------------------------------------------------------------
// Counts the ORIGINAL "Scalper Pro v4.1 [ZynAlgo]" indicator's own TP/SL hit
// events and shows a live scoreboard. A Pine script cannot read another script's
// labels, but it CAN read its plot outputs via input.source(). Scalper Pro exposes
// 8 hit outputs — hook each dropdown below to the matching one:
//   TP1/TP2/TP3 Hit Long, TP1/TP2/TP3 Hit Short, SL Hit Long, SL Hit Short.
// Until you map them, all counts stay 0 (default source `close` never equals 1).
//
// Outcome accounting mirrors Scalper Pro's labels (SL moves up after TP1, so a
// stop only happens pre-TP1):
//   WIN 3R = TP3 hits ; TP +1R = (TP1 hits − TP3 hits) ; SL −1R = SL hits.
//   trades = TP1 hits + SL hits ; wins = TP1 hits ; losses = SL hits.
// =============================================================================
indicator("Scalper Pro — TP/SL Counter [companion]", shorttitle="SP Counter", overlay=true)

gSrc = "Hook to Scalper Pro outputs"
srcTp1L = input.source(close, "TP1 Hit Long",  group=gSrc)
srcTp2L = input.source(close, "TP2 Hit Long",  group=gSrc)
srcTp3L = input.source(close, "TP3 Hit Long",  group=gSrc)
srcSlL  = input.source(close, "SL Hit Long",   group=gSrc)
srcTp1S = input.source(close, "TP1 Hit Short", group=gSrc)
srcTp2S = input.source(close, "TP2 Hit Short", group=gSrc)
srcTp3S = input.source(close, "TP3 Hit Short", group=gSrc)
srcSlS  = input.source(close, "SL Hit Short",  group=gSrc)

gUI   = "Display"
posY  = input.string("Bottom", "Y Position", options=["Top","Middle","Bottom"], group=gUI)
posX  = input.string("Right",  "X Position", options=["Left","Right"], group=gUI)
split = input.bool(true, "Show Long/Short split", group=gUI)

// A hit fires on the bar the output becomes exactly 1 (rising edge so a held value
// is counted once; the `==1` guard ignores the unmapped `close` default).
fired(s) => (not na(s)) and s == 1 and (na(s[1]) or s[1] != 1)

var int tp1L = 0
var int tp2L = 0
var int tp3L = 0
var int slL  = 0
var int tp1S = 0
var int tp2S = 0
var int tp3S = 0
var int slS  = 0
tp1L += fired(srcTp1L) ? 1 : 0
tp2L += fired(srcTp2L) ? 1 : 0
tp3L += fired(srcTp3L) ? 1 : 0
slL  += fired(srcSlL)  ? 1 : 0
tp1S += fired(srcTp1S) ? 1 : 0
tp2S += fired(srcTp2S) ? 1 : 0
tp3S += fired(srcTp3S) ? 1 : 0
slS  += fired(srcSlS)  ? 1 : 0

tp1 = tp1L + tp1S
tp2 = tp2L + tp2S
tp3 = tp3L + tp3S
sl  = slL + slS
win3R   = tp3
tp1only = math.max(0, tp1 - tp3)
trades  = tp1 + sl
winRate = trades > 0 ? 100.0 * tp1 / trades : na
grossW  = win3R * 3.0 + tp1only * 1.0          // R units
grossL  = sl * 1.0
pf      = grossL > 0 ? grossW / grossL : na
expt    = trades > 0 ? (grossW - grossL) / trades : na

// ---------------- scoreboard ----------------
tablePos = posY == "Top" and posX == "Right" ? position.top_right : posY == "Top" and posX == "Left" ? position.top_left : posY == "Middle" and posX == "Right" ? position.middle_right : posY == "Middle" and posX == "Left" ? position.middle_left : posY == "Bottom" and posX == "Right" ? position.bottom_right : position.bottom_left

var table t = na
if barstate.islast
    if not na(t)
        table.delete(t)
    rows = split ? 11 : 8
    t := table.new(tablePos, 3, rows, border_width=1, frame_color=color.new(color.gray, 50), frame_width=1, bgcolor=color.new(#1e222d, 0))
    cT = color.new(color.white, 0)
    cH = color.new(color.gray, 10)
    cG = color.new(#26a69a, 0)
    cR = color.new(#ef5350, 0)
    mapped = trades > 0
    r = 0
    table.cell(t, 0, r, "Scalper Pro — Tally", text_color=cT, text_size=size.normal)
    table.cell(t, 1, r, "", text_color=cT)
    table.cell(t, 2, r, mapped ? "LIVE" : "MAP SRC", text_color=mapped ? cG : cR, text_size=size.normal)
    r += 1
    table.cell(t, 0, r, "WIN 3R", text_color=cT)
    table.cell(t, 1, r, str.tostring(win3R), text_color=cG)
    table.cell(t, 2, r, "+3R", text_color=cH)
    r += 1
    table.cell(t, 0, r, "TP +1R", text_color=cT)
    table.cell(t, 1, r, str.tostring(tp1only), text_color=cG)
    table.cell(t, 2, r, "+1R", text_color=cH)
    r += 1
    table.cell(t, 0, r, "SL −1R", text_color=cT)
    table.cell(t, 1, r, str.tostring(sl), text_color=cR)
    table.cell(t, 2, r, "−1R", text_color=cH)
    r += 1
    table.cell(t, 0, r, "Trades", text_color=cT)
    table.cell(t, 1, r, str.tostring(trades), text_color=cT)
    table.cell(t, 2, r, "W/L " + str.tostring(tp1) + "/" + str.tostring(sl), text_color=cH)
    r += 1
    table.cell(t, 0, r, "Win rate", text_color=cT)
    table.cell(t, 1, r, na(winRate) ? "—" : str.tostring(winRate, "0.0") + "%", text_color=cT)
    table.cell(t, 2, r, "", text_color=cH)
    r += 1
    table.cell(t, 0, r, "Profit Factor", text_color=cT)
    table.cell(t, 1, r, na(pf) ? "—" : str.tostring(pf, "0.00"), text_color=na(pf) ? cT : pf >= 1 ? cG : cR)
    table.cell(t, 2, r, "R", text_color=cH)
    r += 1
    table.cell(t, 0, r, "Expectancy", text_color=cT)
    table.cell(t, 1, r, na(expt) ? "—" : str.tostring(expt, "0.00") + "R", text_color=cT)
    table.cell(t, 2, r, "/trade", text_color=cH)
    if split
        r += 1
        table.cell(t, 0, r, "— per side —", text_color=cH)
        table.cell(t, 1, r, "TP1/2/3", text_color=cH)
        table.cell(t, 2, r, "SL", text_color=cH)
        r += 1
        table.cell(t, 0, r, "Long", text_color=cG)
        table.cell(t, 1, r, str.tostring(tp1L) + "/" + str.tostring(tp2L) + "/" + str.tostring(tp3L), text_color=cT)
        table.cell(t, 2, r, str.tostring(slL), text_color=cR)
        r += 1
        table.cell(t, 0, r, "Short", text_color=cR)
        table.cell(t, 1, r, str.tostring(tp1S) + "/" + str.tostring(tp2S) + "/" + str.tostring(tp3S), text_color=cT)
        table.cell(t, 2, r, str.tostring(slS), text_color=cR)

// expose tallies for alerts / data window
plot(tp1, "TP1 count", display=display.data_window)
plot(tp3, "TP3 (WIN 3R) count", display=display.data_window)
plot(sl,  "SL count", display=display.data_window)
plot(pf,  "Profit Factor", display=display.data_window)
