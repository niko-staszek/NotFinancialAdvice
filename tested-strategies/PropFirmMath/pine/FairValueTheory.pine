//@version=6
// JJ Simon — Fair Value Theory (NQ 1-min helper)
// Sessions, fair-value lines, continuation/mean-rev windows, pivot BOS/MSB (as lines),
// decisive (displacement) candle (white) + same-candle A+ (gold), ATR table,
// integrated S/R zones (ported from LonesomeTheBlue "Support Resistance - Dynamic v2").
// Rules: tested-strategies/PropFirmMath/STRATEGY_RULES.md. Timings verified vs FX Replay.
indicator("JJ Simon — Fair Value Theory", overlay = true, max_lines_count = 500, max_labels_count = 500, max_boxes_count = 500)

// ---------------- Inputs ----------------
gP = "Structure (pivots / BOS-MSB)"
leftBars  = input.int(5, "Pivot left bars",  minval = 1, group = gP)
rightBars = input.int(1, "Pivot right bars", minval = 1, group = gP)

gD = "Decisive / displacement candle"
counterWickPct = input.float(20.0, "Max counter-wick % of range", minval = 1, maxval = 50, group = gD) / 100.0
useSizeGate    = input.bool(false, "Require size gate (optional)", group = gD)
sizeMult       = input.float(1.2, "Size >= x * avg range", minval = 1.0, group = gD)
sizeLookback   = input.int(5, "Size avg lookback", minval = 1, group = gD)
colorWhiteI    = input.bool(true, "Color decisive-only (white) candles", group = gD)

gS = "Sessions (ET)"
tz        = input.string("America/New_York", "Timezone", group = gS)
useLondon = input.bool(true, "03:00 London",  group = gS)
useNews   = input.bool(true, "08:30 News",    group = gS)
useNYAM   = input.bool(true, "09:30 NY AM",   group = gS)
useNYPM   = input.bool(true, "14:00 NY PM",   group = gS)
useReopen = input.bool(true, "18:00 Reopen",  group = gS)
useAsia   = input.bool(true, "20:00 Asia",    group = gS)

gW = "Windows (minutes from open)"
skipFirstMin = input.int(3,  "Continuation skip first N min", minval = 0, group = gW)
contLen      = input.int(15, "Continuation window length",    minval = 1, group = gW)
mrAMlen      = input.int(30, "Mean-rev AM length",            minval = 1, group = gW)
mrPMlen      = input.int(60, "Mean-rev PM length",            minval = 1, group = gW)
blkAM        = input.int(90, "AM block length",    group = gW)
blkPM        = input.int(60, "PM block length",    group = gW)
blkOther     = input.int(90, "Other block length", group = gW)

gA = "ATR"
atrLen = input.int(14, "ATR length", minval = 1, group = gA)

gC = "Colors"
colCont  = input.color(color.new(color.aqua,   90), "Continuation tint", group = gC)
colMR    = input.color(color.new(color.orange, 90), "Mean-rev tint",     group = gC)
colBlock = input.color(color.new(color.gray,   95), "Block background",  group = gC)
colWhite = input.color(color.white,         "Decisive body", group = gC)
colGold  = input.color(color.new(#FFD700, 0),"A+ (gold) body", group = gC)
colFV    = input.color(color.yellow,        "Fair value line", group = gC)
colOpen  = input.color(color.new(color.silver, 0), "Session open line", group = gC)
colBOS   = input.color(color.new(#2962FF, 0), "BOS line", group = gC)
colMSB   = input.color(color.new(#FF6D00, 0), "MSB line", group = gC)

gL = "Line styles & widths"
fvStyleI   = input.string("Solid",  "Fair-value style",   options = ["Solid", "Dashed", "Dotted"], group = gL)
fvWidthI   = input.int(2, "Fair-value width",   minval = 1, maxval = 4, group = gL)
openStyleI = input.string("Solid",  "Session-open style", options = ["Solid", "Dashed", "Dotted"], group = gL)
openWidthI = input.int(1, "Session-open width", minval = 1, maxval = 4, group = gL)
bosStyleI  = input.string("Solid",  "BOS style",          options = ["Solid", "Dashed", "Dotted"], group = gL)
bosWidthI  = input.int(2, "BOS width",          minval = 1, maxval = 4, group = gL)
msbStyleI  = input.string("Solid",  "MSB style",          options = ["Solid", "Dashed", "Dotted"], group = gL)
msbWidthI  = input.int(2, "MSB width",          minval = 1, maxval = 4, group = gL)
srStyleI   = input.string("Dashed", "S/R style",          options = ["Solid", "Dashed", "Dotted"], group = gL)
srWidthI   = input.int(1, "S/R width",          minval = 1, maxval = 4, group = gL)

f_lstyle(s) => s == "Solid" ? line.style_solid : s == "Dashed" ? line.style_dashed : line.style_dotted
fvStyle   = f_lstyle(fvStyleI)
openStyle = f_lstyle(openStyleI)
bosStyle  = f_lstyle(bosStyleI)
msbStyle  = f_lstyle(msbStyleI)
srStyle   = f_lstyle(srStyleI)

// ---------------- Session model ----------------
minOfDay = hour(time, tz) * 60 + minute(time, tz)

var float activeFV       = na
var int   activeOpenMin  = na
var int   activeBlockLen = na
var int   activeMRend    = na
var string activeName    = ""

sStart = array.from(180, 510, 570, 840, 1080, 1200)               // 03:00 08:30 09:30 14:00 18:00 20:00
sName  = array.from("London", "News", "NY AM", "NY PM", "Reopen", "Asia")
sOn    = array.from(useLondon, useNews, useNYAM, useNYPM, useReopen, useAsia)
sBlock = array.from(blkOther, blkOther, blkAM, blkPM, blkOther, blkOther)
sMRend = array.from(blkOther, blkOther, mrAMlen, mrPMlen, blkOther, blkOther)
sIsFV  = array.from(false, false, true, true, false, false)

for i = 0 to 5
    if array.get(sOn, i)
        st = array.get(sStart, i)
        opened = minOfDay >= st and (na(minOfDay[1]) or minOfDay[1] < st)
        if opened
            bl   = array.get(sBlock, i)
            isfv = array.get(sIsFV, i)
            nm   = array.get(sName, i)
            x2t  = time + bl * 60 * 1000
            line.new(time, open, x2t, open, xloc = xloc.bar_time, color = isfv ? colFV : colOpen, width = isfv ? fvWidthI : openWidthI, style = isfv ? fvStyle : openStyle)
            label.new(time + bl * 30 * 1000, open, (isfv ? nm + " FV " : nm + " ") + str.tostring(open, format.mintick), xloc = xloc.bar_time, yloc = yloc.price, style = label.style_none, textcolor = isfv ? colFV : color.silver, size = size.small)
            activeFV       := open
            activeOpenMin  := st
            activeBlockLen := bl
            activeMRend    := array.get(sMRend, i)
            activeName     := nm

if not na(activeFV) and (minOfDay - activeOpenMin) >= activeBlockLen
    activeFV := na

mins      = minOfDay - activeOpenMin
inBlock   = not na(activeFV) and mins >= 0 and mins < activeBlockLen
inContWin = not na(activeFV) and mins >= skipFirstMin and mins < contLen
inMRWin   = not na(activeFV) and mins >= contLen and mins < activeMRend

bgcolor(inContWin ? colCont : inMRWin ? colMR : inBlock ? colBlock : na, title = "Window tint")

// ---------------- Pivots & structure break (FX Replay rule: close past recent pivot) ----------------
ph = ta.pivothigh(leftBars, rightBars)
pl = ta.pivotlow(leftBars, rightBars)
var float pH = na
var int   pHbar = na
var float pL = na
var int   pLbar = na
if not na(ph)
    pH := ph
    pHbar := bar_index - rightBars
if not na(pl)
    pL := pl
    pLbar := bar_index - rightBars

upBreak   = not na(pH) and close > pH and close[1] <= pH
downBreak = not na(pL) and close < pL and close[1] >= pL

aboveFV = not na(activeFV) and close > activeFV
belowFV = not na(activeFV) and close < activeFV

// away from FV = BOS (continuation); toward FV = MSB (reversal)
isBOS = (aboveFV and upBreak) or (belowFV and downBreak)
isMSB = (aboveFV and downBreak) or (belowFV and upBreak)
brokeStruct = isBOS or isMSB

// BOS/MSB drawn as a LINE at the broken structure level
brokeY    = upBreak ? pH : downBreak ? pL : na
brokeFrom = upBreak ? pHbar : downBreak ? pLbar : na
if (isBOS or isMSB) and not na(brokeY) and not na(brokeFrom)
    bcol = isBOS ? colBOS : colMSB
    // line connects the pivot that formed the level to the candle that broke it
    line.new(brokeFrom, brokeY, bar_index, brokeY, xloc = xloc.bar_index, color = bcol, width = isBOS ? bosWidthI : msbWidthI, style = isBOS ? bosStyle : msbStyle)
    // plain text centered on the line (no bubble)
    label.new(int((brokeFrom + bar_index) / 2), brokeY, isBOS ? "BOS" : "MSB", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = bcol, size = size.small)

// ---------------- Decisive (displacement) candle ----------------
rng     = high - low
cwick   = close >= open ? open - low : high - open       // wick against the close direction
decisive = rng > 0 and (cwick / rng) <= counterWickPct
avgRng  = ta.sma(high - low, sizeLookback)
sizeOK  = not useSizeGate or (high - low) >= sizeMult * nz(avgRng[1])
decisiveFull = decisive and sizeOK

gold  = decisiveFull and brokeStruct
white = decisiveFull and not gold

// Recolor the ACTUAL bars (barcolor draws on the main series → always visible).
// plotcandle bodies render BEHIND the chart's candles unless the indicator is brought to front,
// which is why they only showed on hover/select.
barcolor(gold ? colGold : (white and colorWhiteI) ? colWhite : na, title = "Signal candle (white=decisive, gold=A+)")

// ---------------- Recommendation ----------------
rec = "None"
if inContWin and decisiveFull and isBOS
    rec := aboveFV ? "Continuation BUY" : "Continuation SELL"
else if inMRWin and decisiveFull and isMSB
    rec := aboveFV ? "Reversion SELL" : "Reversion BUY"

// ---------------- ATR + table ----------------
atr    = ta.atr(atrLen)
bucket = atr > 20 ? "HIGH" : atr >= 7 ? "MID" : "LOW"
slTp   = atr > 20 ? "50 / 75" : atr >= 7 ? "25 / 37.5" : "16.5 / 24.75"

// ---------------- Trade outcome boxes (open -> TP/SL close) ----------------
gT = "Trade boxes"
showTrades  = input.bool(true, "Show trade boxes", group = gT)
tradesInWin = input.bool(false, "Only in-window (recommended) setups", group = gT)
maxHold     = input.int(240, "Max bars to hold (force-close)", minval = 10, group = gT)
tpBoxCol    = input.color(color.new(color.green, 75), "TP (win) box", group = gT)
slBoxCol    = input.color(color.new(color.red,   75), "SL (loss) box", group = gT)

slPts = atr > 20 ? 50.0 : atr >= 7 ? 25.0 : 16.5
tpPts = atr > 20 ? 75.0 : atr >= 7 ? 37.5 : 24.75

var tBar   = array.new_int(0)
var tEntry = array.new_float(0)
var tTP    = array.new_float(0)
var tSL    = array.new_float(0)
var tLong  = array.new_bool(0)

// open a trade on a gold A+ signal
if showTrades and gold and (not tradesInWin or rec != "None")
    long = upBreak                                  // gold => broke structure; up-break = long
    array.push(tBar, bar_index)
    array.push(tEntry, close)
    array.push(tTP, long ? close + tpPts : close - tpPts)
    array.push(tSL, long ? close - slPts : close + slPts)
    array.push(tLong, long)

// resolve open trades when price touches TP or SL (or force-close after maxHold)
if showTrades
    i = 0
    while i < array.size(tBar)
        long  = array.get(tLong, i)
        etp   = array.get(tTP, i)
        esl   = array.get(tSL, i)
        eb    = array.get(tBar, i)
        een   = array.get(tEntry, i)
        hitTP = long ? high >= etp : low <= etp
        hitSL = long ? low <= esl : high >= esl
        if hitTP or hitSL or (bar_index - eb >= maxHold)
            won = hitTP and not hitSL               // both same bar -> count as SL (conservative)
            lvl = won ? etp : hitSL ? esl : close
            box.new(eb, math.max(een, lvl), bar_index, math.min(een, lvl), border_color = na, bgcolor = won ? tpBoxCol : slBoxCol)
            label.new(bar_index, lvl, won ? "TP" : hitSL ? "SL" : "×", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = won ? color.green : color.red, size = size.small)
            array.remove(tBar, i)
            array.remove(tEntry, i)
            array.remove(tTP, i)
            array.remove(tSL, i)
            array.remove(tLong, i)
        else
            i += 1

tblPosInput = input.string("bottom_right", "Table position", options = ["top_right", "top_left", "bottom_right", "bottom_left"], group = gA)
tblPos = tblPosInput == "top_left" ? position.top_left : tblPosInput == "bottom_right" ? position.bottom_right : tblPosInput == "bottom_left" ? position.bottom_left : position.top_right
var table tbl = table.new(tblPos, 2, 9, border_width = 1, frame_color = color.new(color.gray, 40), frame_width = 1)
f_cell(col, row, txt, txtcol, bg) => table.cell(tbl, col, row, txt, text_color = txtcol, text_size = size.small, bgcolor = bg)
if barstate.islast
    hdrBg = color.new(color.black, 0)
    rowBg = color.new(color.black, 25)
    winCol = inContWin ? color.aqua : inMRWin ? color.orange : color.gray
    recCol = rec == "None" ? color.gray : str.contains(rec, "BUY") ? color.lime : color.red
    f_cell(0, 0, "Fair Value Theory", color.yellow, hdrBg)
    f_cell(1, 0, na(activeFV) ? "—" : activeName, color.yellow, hdrBg)
    f_cell(0, 1, "Fair Value", color.white, rowBg)
    f_cell(1, 1, na(activeFV) ? "—" : str.tostring(activeFV, format.mintick), color.yellow, rowBg)
    f_cell(0, 2, "ATR(" + str.tostring(atrLen) + ")", color.white, rowBg)
    f_cell(1, 2, str.tostring(atr, "#.0") + "  " + bucket, bucket == "HIGH" ? color.red : bucket == "MID" ? color.orange : color.lime, rowBg)
    f_cell(0, 3, "SL / TP (pts)", color.white, rowBg)
    f_cell(1, 3, slTp, color.white, rowBg)
    f_cell(0, 4, "Decisive", color.white, rowBg)
    f_cell(1, 4, decisiveFull ? "✓" : "✗", decisiveFull ? color.lime : color.gray, rowBg)
    f_cell(0, 5, "BOS", color.white, rowBg)
    f_cell(1, 5, isBOS ? "✓" : "✗", isBOS ? color.lime : color.gray, rowBg)
    f_cell(0, 6, "MSB", color.white, rowBg)
    f_cell(1, 6, isMSB ? "✓" : "✗", isMSB ? color.lime : color.gray, rowBg)
    f_cell(0, 7, "Window", color.white, rowBg)
    f_cell(1, 7, inContWin ? "Continuation" : inMRWin ? "Mean-rev" : inBlock ? "Block" : "—", winCol, rowBg)
    f_cell(0, 8, "Trade", color.white, rowBg)
    f_cell(1, 8, rec, recCol, rec == "None" ? rowBg : color.new(recCol, 75))

// ================= S/R zones (ported v5->v6 from "Support Resistance - Dynamic v2", © LonesomeTheBlue, MPL-2.0) =================
gSR = "S/R zones"
showSR     = input.bool(true,  "Show S/R zones", group = gSR)
srPrd      = input.int(10, "S/R Pivot Period", minval = 4, maxval = 30, group = gSR)
srPpsrc    = input.string("High/Low", "S/R Source", options = ["High/Low", "Close/Open"], group = gSR)
srMaxpp    = input.int(20, "S/R Max Pivots", minval = 5, maxval = 100, group = gSR)
srChanW    = input.int(10, "S/R Max Channel Width %", minval = 1, group = gSR)
srMaxsr    = input.int(5,  "S/R Max Levels", minval = 1, maxval = 10, group = gSR)
srMinStr   = input.int(2,  "S/R Min Strength", minval = 1, maxval = 10, group = gSR)
srLabelLoc = input.int(20, "S/R Label Location", group = gSR)
srResCol   = input.color(color.red,  "Resistance Color", group = gSR)
srSupCol   = input.color(color.lime, "Support Color", group = gSR)

srSrc1 = srPpsrc == "High/Low" ? high : math.max(close, open)
srSrc2 = srPpsrc == "High/Low" ? low  : math.min(close, open)
srph = ta.pivothigh(srSrc1, srPrd, srPrd)
srpl = ta.pivotlow(srSrc2, srPrd, srPrd)

var pivotvals = array.new_float(0)
if not na(srph) or not na(srpl)
    array.unshift(pivotvals, not na(srph) ? srph : srpl)
    if array.size(pivotvals) > srMaxpp
        array.pop(pivotvals)

prdhighest = ta.highest(300)
prdlowest  = ta.lowest(300)
cwidth = (prdhighest - prdlowest) * srChanW / 100

get_sr_vals(ind) =>
    float lo = array.get(pivotvals, ind)
    float hi = lo
    int numpp = 0
    for y = 0 to array.size(pivotvals) - 1
        float cpp = array.get(pivotvals, y)
        float wdth = cpp <= lo ? hi - cpp : cpp - lo
        if wdth <= cwidth
            if cpp <= hi
                lo := math.min(lo, cpp)
            else
                hi := math.max(hi, cpp)
            numpp += 1
    [hi, lo, numpp]

var sr_up_level = array.new_float(0)
var sr_dn_level = array.new_float(0)
sr_strength = array.new_float(0)

find_loc(strength) =>
    sz = array.size(sr_strength)
    ret = sz
    if sz > 0
        for i = sz - 1 to 0
            if strength <= array.get(sr_strength, i)
                break
            ret := i
    ret

check_sr(hi, lo, strength) =>
    ret = true
    if array.size(sr_up_level) > 0
        for i = 0 to array.size(sr_up_level) - 1
            if (array.get(sr_up_level, i) >= lo and array.get(sr_up_level, i) <= hi) or (array.get(sr_dn_level, i) >= lo and array.get(sr_dn_level, i) <= hi)
                if strength >= array.get(sr_strength, i)
                    array.remove(sr_strength, i)
                    array.remove(sr_up_level, i)
                    array.remove(sr_dn_level, i)
                else
                    ret := false
                break
    ret

var sr_lines  = array.new_line(11, na)
var sr_labels = array.new_label(11, na)

if showSR
    for x = 1 to 10
        ln = array.get(sr_lines, x)
        lb = array.get(sr_labels, x)
        if not na(lb)
            yv = label.get_y(lb)
            rate = 100 * (yv - close) / close
            label.set_text(lb, str.tostring(yv) + " (" + str.tostring(rate, "#.##") + "%)")
            label.set_x(lb, bar_index + srLabelLoc)
            label.set_textcolor(lb, yv >= close ? srResCol : srSupCol)
            label.set_style(lb, label.style_none)
        if not na(ln)
            line.set_color(ln, line.get_y1(ln) >= close ? srResCol : srSupCol)

if showSR and (not na(srph) or not na(srpl))
    array.clear(sr_up_level)
    array.clear(sr_dn_level)
    array.clear(sr_strength)
    for x = 0 to array.size(pivotvals) - 1
        [hi, lo, strength] = get_sr_vals(x)
        if check_sr(hi, lo, strength)
            loc = find_loc(strength)
            if loc < srMaxsr and strength >= srMinStr
                array.insert(sr_strength, loc, strength)
                array.insert(sr_up_level, loc, hi)
                array.insert(sr_dn_level, loc, lo)
                if array.size(sr_strength) > srMaxsr
                    array.pop(sr_strength)
                    array.pop(sr_up_level)
                    array.pop(sr_dn_level)
    for x = 1 to 10
        line.delete(array.get(sr_lines, x))
        label.delete(array.get(sr_labels, x))
    if array.size(sr_up_level) > 0
        for x = 0 to array.size(sr_up_level) - 1
            float mid = math.round_to_mintick((array.get(sr_up_level, x) + array.get(sr_dn_level, x)) / 2)
            rate = 100 * (mid - close) / close
            array.set(sr_labels, x + 1, label.new(x = bar_index + srLabelLoc, y = mid, text = str.tostring(mid) + " (" + str.tostring(rate, "#.##") + "%)", textcolor = mid >= close ? srResCol : srSupCol, style = label.style_none))
            array.set(sr_lines, x + 1, line.new(x1 = bar_index, y1 = mid, x2 = bar_index - 1, y2 = mid, extend = extend.both, color = mid >= close ? srResCol : srSupCol, style = srStyle, width = srWidthI))
